# ─── Deployment mode ──────────────────────────────────────────────
# single_tenant = white-label license deploy (one admin user, no signup)
# multi_tenant  = SaaS deploy (Whop checkout + magic-link signup)
DEPLOYMENT_MODE=single_tenant

# ─── App secrets ──────────────────────────────────────────────────
# 32-byte URL-safe base64 key. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=

# Single-tenant admin bootstrap (Mode A only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# ─── LLM providers (BYOK) ─────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── Image providers (BYOK; Pexels/Unsplash are free, just need a dev key) ──
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
# Nano Banana = google-genai with model gemini-2.5-flash-image; uses GEMINI_API_KEY above

# ─── Voice / music ────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ─── Topic sources (optional) ─────────────────────────────────────
NEWSDATA_API_KEY=
NEWSCATCHER_API_KEY=

# ─── Social platforms (Mode A: customer's own apps; Mode B: master apps) ──
META_APP_ID=
META_APP_SECRET=
META_PAGE_TOKEN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_API_KEY=

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Public base URL of this backend (used to construct OAuth callback URLs).
# Local dev = http://localhost:8000. In Railway use the public domain Railway gives you.
PUBLIC_BASE_URL=http://localhost:8000

# ─── Storage (optional R2/S3) ─────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ─── Whop (Mode B billing — required for SaaS mode) ───────────────
# Webhook signing secret from your Whop product's webhook settings.
# Without this set, the webhook endpoint rejects all requests in multi_tenant mode.
WHOP_WEBHOOK_SECRET=

# ─── Transactional email (Mode B — magic-link signup) ─────────────
# Resend API key (resend.com). When unset, magic-link URLs are LOGGED to stdout
# instead of emailed — fine for dev, not for production.
RESEND_API_KEY=
# From-address shown to recipients. Must match a domain you've verified in Resend.
EMAIL_FROM=Summit Automates <noreply@summitautomates.com>

# ─── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_JSON=false
